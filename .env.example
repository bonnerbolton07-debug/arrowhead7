# =============================================================================
# Arrowhead 7 — Environment Variables
# =============================================================================
# Copy to .env.local and fill in your values

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Shotstack ───────────────────────────────────────────────────────────────
SHOTSTACK_STAGE_API_KEY=your-stage-key
SHOTSTACK_PROD_API_KEY=your-prod-key
SHOTSTACK_API_URL=https://api.shotstack.io/edit/stage
# Stage: https://api.shotstack.io/edit/stage  (free tier, watermarked)
# Prod:  https://api.shotstack.io/edit/v1     (paid, no watermark)

# ─── Cloudflare ──────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-account-id

# R2 Storage (S3-compatible)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=arrowhead7-processing

# Cloudflare Stream
CLOUDFLARE_STREAM_API_TOKEN=your-stream-api-token

# ─── Stripe (for subscriptions) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key

# Stripe price IDs (create products + prices in Stripe Dashboard, paste IDs here)
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_STUDIO_MONTHLY=price_xxx

# ─── OpenAI (Auto-Captions / Whisper) ────────────────────────────────────────
# When unset, the /api/captions/transcribe route returns 503 and the editor
# disables the auto-captions toggle gracefully.
OPENAI_API_KEY=sk-your-openai-key

# ─── Watermark (free tier) ───────────────────────────────────────────────────
# Optional. When set, free-tier renders include the A7 logo image as a small,
# semi-transparent corner watermark. When unset, a "Made with A7" text title
# is used instead.
NEXT_PUBLIC_A7_WATERMARK_URL=

# ─── Style DNA analyser ─────────────────────────────────────────────────────
# The analyser shells out to ffmpeg/ffprobe. The @ffmpeg-installer and
# @ffprobe-installer packages bundle binaries by default; override with these
# vars if you want to use a system install instead.
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# FFPROBE_PATH=/usr/local/bin/ffprobe
# Optional: yt-dlp binary path for social URL ingestion (Instagram/TikTok/YT/X)
# YTDLP_PATH=yt-dlp

# ─── AI Soundtrack Generation (optional) ────────────────────────────────────
# When either of these is configured the editor offers to generate an original
# soundtrack matching the reference's vibe (zero-copyright). Without keys the
# editor's render path still works, but no soundtrack is attached.
# MUBERT_API_KEY=
# MUBERT_API_URL=https://api-b2b.mubert.com/v2/TTMRecordTrack
# SOUNDRAW_API_KEY=
# SOUNDRAW_API_URL=https://api.soundraw.io/v1/generate

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Token Encryption ───────────────────────────────────────────────────────
# 32 bytes, base64-encoded. Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ─── Cloud Storage OAuth ────────────────────────────────────────────────────
# Google (used for both Drive and YouTube — same OAuth client).
# https://console.cloud.google.com/apis/credentials
# Redirect URIs to register:
#   {NEXT_PUBLIC_APP_URL}/api/auth/google-drive/callback
#   {NEXT_PUBLIC_APP_URL}/api/auth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dropbox — https://www.dropbox.com/developers/apps
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/dropbox/callback
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# ─── Publishing Platform OAuth ──────────────────────────────────────────────
# TikTok Content Posting API — https://developers.tiktok.com/
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Facebook (Instagram Graph API) — https://developers.facebook.com/apps
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/instagram/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# X (Twitter) v2 — OAuth 2.0 with PKCE — https://developer.twitter.com/en/portal/dashboard
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/x/callback
X_CLIENT_ID=
X_CLIENT_SECRET=

# ─── Scheduler Cron ─────────────────────────────────────────────────────────
# Vercel Cron hits /api/distribute/cron with `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=
